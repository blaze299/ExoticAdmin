<Window x:Class="ExoticAdmin.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exotic Rentals - Login" Height="500" Width="850"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None"
        Background="#121212">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentGold" Color="#FFB300"/>
        <SolidColorBrush x:Key="PanelBg" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="InputBg" Color="#222222"/>
        
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GoldLoginButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGold}"/>
            <Setter Property="Foreground" Value="#121212"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0,18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <Image Source="pack://application:,,,/Images/Exotic_logo.png" Width="110" Stretch="Uniform" Margin="-4,0,0,-5" HorizontalAlignment="Left">
                    <Image.Clip>
                        <RectangleGeometry Rect="0,0,110,110" RadiusX="10" RadiusY="10"/>
                    </Image.Clip>
                </Image>

                <TextBlock Text="EXOTIC" Foreground="White" FontSize="54" FontWeight="Black" Margin="0,0,0,-10"/>
                <TextBlock Text="RENTALS" Foreground="{StaticResource AccentGold}" FontSize="54" FontWeight="Black"/>

                <Rectangle Height="3" Width="60" Fill="{StaticResource AccentGold}" HorizontalAlignment="Left" Margin="5,20,0,20"/>

                <TextBlock Text="FLOTTAKEZELŐ RENDSZER" Foreground="#888888" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="{StaticResource PanelBg}">
            <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15" Background="Transparent" BorderThickness="0" Foreground="#888" FontSize="16" FontWeight="Bold" Cursor="Hand" Click="BtnClose_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <StackPanel VerticalAlignment="Center" Margin="40">
                <TextBlock Text="Bejelentkezés" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Add meg a bejelentkezési adataidat." Foreground="#888" FontSize="14" Margin="0,0,0,40"/>

                <TextBlock Text="Email cím" Foreground="#CCC" FontSize="13" Margin="0,0,0,8"/>
                <TextBox x:Name="txtEmail" Margin="0,0,0,20"/>

                <TextBlock Text="Jelszó" Foreground="#CCC" FontSize="13" Margin="0,0,0,8"/>
                <PasswordBox x:Name="txtPassword" Margin="0,0,0,40"/>

                <Button Content="Bejelentkezés" Style="{StaticResource GoldLoginButtonStyle}" Click="BtnLogin_Click" Height="40"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>