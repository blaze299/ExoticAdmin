<Window x:Class="ExoticAdmin.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Felhasználó Részletes Adatai" Height="650" Width="450"
        Background="{StaticResource PrimaryBlack}" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,15,0,5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="FELHASZNÁLÓ KEZELÉSE" Foreground="{StaticResource AccentGold}" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
            <StackPanel>

                <TextBlock Text="Felhasználónév (Kötelező)"/>
                <TextBox x:Name="txtUsername"/>

                <TextBlock Text="Teljes név"/>
                <TextBox x:Name="txtFullName"/>

                <TextBlock Text="Email cím (Kötelező)"/>
                <TextBox x:Name="txtEmail"/>

                <TextBlock Text="Telefonszám"/>
                <TextBox x:Name="txtPhone"/>

                <TextBlock Text="Születési dátum (ÉÉÉÉ-HH-NN)"/>
                <TextBox x:Name="txtDob"/>

                <TextBlock Text="Jogosultsági szint (1=User, 2=Sofőr, 3=Admin)"/>
                <TextBox x:Name="txtClearance"/>

                <TextBlock Text="Jogosítvány száma (Opcionális)"/>
                <TextBox x:Name="txtLicense"/>

                <TextBlock Text="Jogosítvány lejárata (ÉÉÉÉ-HH-NN)"/>
                <TextBox x:Name="txtLicenseExpiry"/>

                <Rectangle Height="1" Fill="#444" Margin="0,20,0,10"/>
                <TextBlock Text="🚨 Adminisztrátori Beállítások" Foreground="#FF6B6B" FontSize="16" FontWeight="Bold"/>

                <CheckBox x:Name="chkIsBanned" Content="🚫 FELHASZNÁLÓ TILTÁSA (Feketelista)" Foreground="#FF6B6B" FontSize="14" FontWeight="Bold" Margin="0,10,0,10"/>

                <TextBlock Text="Belső megjegyzés (Ügyfél nem látja)"/>
                <TextBox x:Name="txtAdminNotes" TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                <CheckBox x:Name="chkIsVerified" Content="Fiók hitelesítve (Verified)" Foreground="{StaticResource AccentGold}" FontSize="14" Margin="0,20,0,10"/>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Button Content="🔑 Új jelszó generálása" Style="{StaticResource FlatButtonStyle}" Width="160" Padding="12" Background="#2196F3" Foreground="White" BorderThickness="0" Click="BtnGeneratePassword_Click" Cursor="Hand" HorizontalAlignment="Left"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Mégse" Style="{StaticResource FlatButtonStyle}" Width="80" Padding="12" Background="#444" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="BtnCancel_Click" Cursor="Hand"/>
                <Button Content="Mentés" Style="{StaticResource FlatButtonStyle}" Width="100" Padding="12" Background="{StaticResource AccentGold}" Foreground="Black" FontWeight="Bold" BorderThickness="0" Click="BtnSave_Click" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>