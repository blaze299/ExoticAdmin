<Window x:Class="ExoticAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exotic Rentals - Admin Panel" Height="750" Width="1200"
        Background="{StaticResource SecondaryDark}" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentGold}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBlack}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PrimaryBlack}" Padding="15">
            <StackPanel>
                <TextBlock Text="EXOTIC RENTALS" Foreground="{StaticResource AccentGold}" FontSize="24" FontWeight="Bold" Margin="0,20,0,50" TextAlignment="Center"/>
                <Button x:Name="btnMenuVehicles" Content="AUTÓK KEZELÉSE" Style="{StaticResource GoldButtonStyle}" Margin="0,0,0,15" Click="BtnMenuVehicles_Click"/>
                <Button x:Name="btnMenuUsers" Content="FELHASZNÁLÓK" Style="{StaticResource GoldButtonStyle}" Background="Transparent" Foreground="{StaticResource AccentGold}" Margin="0,0,0,15" Click="BtnMenuUsers_Click"/>
                <Button x:Name="btnMenuDrivers" Content="SOFŐRÖK" Style="{StaticResource GoldButtonStyle}" Background="Transparent" Foreground="{StaticResource AccentGold}" Click="BtnMenuDrivers_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">

            <Grid x:Name="pnlVehicles" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Autók listája" Foreground="{StaticResource TextWhite}" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="Kategória:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="cmbCategoryFilter" Width="130" FontSize="14" SelectionChanged="FilterVehicles_Changed" Padding="5" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Összes" IsSelected="True"/>
                        <ComboBoxItem Content="Sedan"/>
                        <ComboBoxItem Content="Coupe"/>
                        <ComboBoxItem Content="Hatchback"/>
                        <ComboBoxItem Content="SUV"/>
                        <ComboBoxItem Content="Wagon"/>
                        <ComboBoxItem Content="Minivan"/>
                        <ComboBoxItem Content="Luxury"/>
                        <ComboBoxItem Content="Cabriolet"/>
                    </ComboBox>

                    <TextBlock Text="Keresés:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="20,0,10,0"/>
                    <TextBox x:Name="txtSearchVehicle" Width="200" Style="{StaticResource SearchTextBoxStyle}" TextChanged="FilterVehicles_Changed"/>

                    <Button Content="+ Új autó" Style="{StaticResource GoldButtonStyle}" Margin="30,0,0,0" Click="BtnAddVehicle_Click"/>
                </StackPanel>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="icVehicles">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A1A" CornerRadius="8" Margin="0,0,20,15" BorderBrush="#333" BorderThickness="1" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentGold}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Brand}" Foreground="White" FontSize="22" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Model}" Foreground="#CCCCCC" FontSize="16"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <TextBlock Text="Státusz: " Foreground="Gray" FontSize="13"/>
                                                <TextBlock Text="{Binding StatusName}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="13" Margin="0,0,15,0"/>
                                                <TextBlock Text="Bérlések száma: " Foreground="Gray" FontSize="13"/>
                                                <TextBlock Text="{Binding TimesRented}" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Year}" Foreground="Gray" FontSize="14" Margin="0,0,0,5"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding PricePerDay}" Foreground="{StaticResource AccentGold}" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" € / nap" Foreground="{StaticResource AccentGold}" FontSize="16"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="✏️ Szerkesztés" Style="{StaticResource CardButtonStyle}" Click="BtnEdit_Click"/>
                                            <Button Content="🗑️ Törlés" Style="{StaticResource CardButtonStyle}" Foreground="#FF6B6B" Margin="10,0,0,0" Click="BtnDelete_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="pnlUsers" Visibility="Hidden">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Felhasználók listája" Foreground="White" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="Szűrés:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="cmbUserFilter" Width="130" FontSize="14" SelectionChanged="FilterUsers_Changed" Padding="5" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Összes" IsSelected="True"/>
                        <ComboBoxItem Content="Admin"/>
                        <ComboBoxItem Content="Sofőr"/>
                        <ComboBoxItem Content="User"/>
                    </ComboBox>

                    <TextBlock Text="Keresés:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="20,0,10,0"/>
                    <TextBox x:Name="txtSearchUser" Width="200" Style="{StaticResource SearchTextBoxStyle}" TextChanged="FilterUsers_Changed"/>
                </StackPanel>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icUsers">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A1A" CornerRadius="8" Margin="0,0,20,15" BorderBrush="#333" BorderThickness="1" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding RoleName}" Foreground="{StaticResource AccentGold}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Username}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding FullName}" Foreground="#CCC" FontSize="14"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Email}" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="{Binding PhoneNumber}" Foreground="Gray" FontSize="14"/>
                                            <TextBlock Text="{Binding VerifiedText}" Foreground="{Binding VerifiedColor}" FontSize="13" FontWeight="Bold" Margin="0,5,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="✏️ Szerkesztés" Style="{StaticResource CardButtonStyle}" Click="BtnEditUser_Click"/>
                                            <Button Content="🗑️ Törlés" Style="{StaticResource CardButtonStyle}" Foreground="#FF6B6B" Margin="10,0,0,0" Click="BtnDeleteUser_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="pnlDrivers" Visibility="Hidden">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="Sofőrök listája" Foreground="White" FontSize="32" FontWeight="SemiBold"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icDrivers">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A1A" CornerRadius="8" Margin="0,0,20,15" BorderBrush="#333" BorderThickness="1" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding RoleName}" Foreground="{StaticResource AccentGold}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding FullName}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Username}" Foreground="#CCC" FontSize="14"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Email}" Foreground="White" FontSize="14"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Jogsi: " Foreground="Gray" FontSize="14"/>
                                                <TextBlock Text="{Binding LicenseNumber}" Foreground="{StaticResource AccentGold}" FontSize="14" FontWeight="Bold"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding VerifiedText}" Foreground="{Binding VerifiedColor}" FontSize="13" FontWeight="Bold" Margin="0,5,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="✏️ Szerkesztés" Style="{StaticResource CardButtonStyle}" Click="BtnEditUser_Click"/>
                                            <Button Content="🗑️ Törlés" Style="{StaticResource CardButtonStyle}" Foreground="#FF6B6B" Margin="10,0,0,0" Click="BtnDeleteUser_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</Window>
