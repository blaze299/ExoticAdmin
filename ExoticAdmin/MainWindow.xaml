<Window x:Class="ExoticAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exotic Rentals - Admin Panel" Height="750" Width="1200"
        Background="{StaticResource SecondaryDark}" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" />
        </Storyboard>

        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentGold}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBlack}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PrimaryBlack}" Padding="15" Panel.ZIndex="10">
            <StackPanel>
                <StackPanel HorizontalAlignment="Center" Margin="0,15,0,40">
                    <Image Source="pack://application:,,,/Images/Exotic_logo.jpg" Width="90" Stretch="Uniform" Margin="0,0,0,-5" HorizontalAlignment="Center">
                        <Image.Clip>
                            <RectangleGeometry Rect="0,0,90,90" RadiusX="8" RadiusY="8"/>
                        </Image.Clip>
                    </Image>
                    <TextBlock Text="EXOTIC RENTALS" Foreground="{StaticResource AccentGold}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Left"/>
                </StackPanel>

                <Button x:Name="btnMenuHome" Content="KEZDŐLAP" Style="{StaticResource GoldButtonStyle}" Margin="0,0,0,15" Click="BtnMenuHome_Click"/>
                <Button x:Name="btnMenuOrders" Content="BÉRLÉSEK" Style="{StaticResource GoldButtonStyle}" Background="Transparent" Foreground="{StaticResource AccentGold}" Margin="0,0,0,15" Click="BtnMenuOrders_Click"/>
                <Button x:Name="btnMenuVehicles" Content="AUTÓK KEZELÉSE" Style="{StaticResource GoldButtonStyle}" Background="Transparent" Foreground="{StaticResource AccentGold}" Margin="0,0,0,15" Click="BtnMenuVehicles_Click"/>
                <Button x:Name="btnMenuUsers" Content="FELHASZNÁLÓK" Style="{StaticResource GoldButtonStyle}" Background="Transparent" Foreground="{StaticResource AccentGold}" Margin="0,0,0,15" Click="BtnMenuUsers_Click"/>
                <Button x:Name="btnMenuDrivers" Content="SOFŐRÖK" Style="{StaticResource GoldButtonStyle}" Background="Transparent" Foreground="{StaticResource AccentGold}" Click="BtnMenuDrivers_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">

            <Grid x:Name="pnlHome" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="txtWelcome" Text="Üdvözlünk!" Foreground="{StaticResource AccentGold}" FontSize="32" FontWeight="Bold" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1">
                    <TextBlock Text="Itt kezelheted a flottát, a bérléseket és a felhasználókat." Foreground="#CCCCCC" FontSize="18" Margin="0,0,0,30"/>
                    <WrapPanel Margin="0,0,0,20">
                        <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="20" Width="190" Margin="0,0,20,20">
                            <StackPanel>
                                <TextBlock Text="🚗 Összes Autó" Foreground="Gray" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtStatVehicles" Text="-" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="20" Width="190" Margin="0,0,20,20">
                            <StackPanel>
                                <TextBlock Text="👥 Felhasználók Száma" Foreground="Gray" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtStatUsers" Text="-" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="20" Width="190" Margin="0,0,20,20">
                            <StackPanel>
                                <TextBlock Text="👔 Sofőrök Száma" Foreground="Gray" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtStatDrivers" Text="-" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="20" Width="190" Margin="0,0,20,20">
                            <StackPanel>
                                <TextBlock Text="💰 Napi Bevétel" Foreground="Gray" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtStatRevenue" Text="-" Foreground="#4CAF50" FontSize="36" FontWeight="Bold" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                    <ItemsControl x:Name="icAlerts" Margin="0,0,0,20">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#4A1515" BorderBrush="#FF6B6B" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠️" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="15" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6*"/>
                            <ColumnDefinition Width="4*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Bevételek alakulása (Legutóbbiak)" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="20">
                                <ItemsControl x:Name="icChart">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="Gray" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Rectangle Width="{Binding Width}" Height="20" Fill="{StaticResource AccentGold}" RadiusX="3" RadiusY="3"/>
                                                    <TextBlock Text="{Binding DisplayValue}" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="🔥 Legnépszerűbb Autók" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="15">
                                <ItemsControl x:Name="icTopCars">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#333" CornerRadius="5" Width="60" Height="40" Margin="0,0,10,0">
                                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill">
                                                        <Image.Clip>
                                                            <RectangleGeometry Rect="0,0,60,40" RadiusX="5" RadiusY="5"/>
                                                        </Image.Clip>
                                                    </Image>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Brand}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text="{Binding Model}" Foreground="Gray" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding TimesRented}" Foreground="{StaticResource AccentGold}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="bérlés" Foreground="Gray" FontSize="10"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid x:Name="pnlOrders" Visibility="Hidden">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Bérlések kezelése" Foreground="White" FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <Button Content="📄 Exportálás CSV-be" Style="{StaticResource GoldButtonStyle}" HorizontalAlignment="Right" Click="BtnExportOrders_Click"/>
                </Grid>
                <TextBlock Grid.Row="1" Text="Itt látható az összes eddigi és folyamatban lévő bérlés rendszerezve." Foreground="#CCCCCC" FontSize="16" Margin="0,0,0,15"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center">
                    <Button Content="+ Új bérlés" Style="{StaticResource GoldButtonStyle}" Click="BtnAddOrder_Click" Margin="0,0,20,0"/>
                    <TextBlock Text="Státusz:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cmbOrderStatusFilter" Width="120" FontSize="14" SelectionChanged="FilterOrders_Changed" Padding="5" VerticalContentAlignment="Center" Margin="0,0,20,0">
                        <ComboBoxItem Content="Összes" IsSelected="True"/>
                        <ComboBoxItem Content="Függőben"/>
                        <ComboBoxItem Content="Aktív"/>
                        <ComboBoxItem Content="Befejezve"/>
                    </ComboBox>
                    <TextBlock Text="Keresés:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="txtSearchOrder" Width="200" Style="{StaticResource SearchTextBoxStyle}" TextChanged="FilterOrders_Changed"/>
                </StackPanel>

                <Border Grid.Row="3" Background="#1A1A1A" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="20,20,5,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="5,0,25,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ÜGYFÉL &amp; AUTÓ" Foreground="{StaticResource AccentGold}" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="IDŐTARTAM" Foreground="{StaticResource AccentGold}" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Grid.Column="2" Text="STÁTUSZ &amp; ÁR" Foreground="{StaticResource AccentGold}" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Grid.Column="3" Text="ÁLLAPOT" Foreground="{StaticResource AccentGold}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="MŰVELET" Foreground="{StaticResource AccentGold}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                        </Grid>
                        <Rectangle Grid.Row="1" Height="1" Fill="#333" Margin="0,0,15,15"/>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icOrders">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="5,10,5,15" Margin="0,0,15,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="110"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CustomerName}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding VehicleName}" Foreground="#CCC" FontSize="14" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Kezdés: " Foreground="Gray" FontSize="13"/>
                                                        <TextBlock Text="{Binding StartDate, StringFormat=yyyy. MM. dd.}" Foreground="White" FontSize="13"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="Vége: " Foreground="Gray" FontSize="13"/>
                                                        <TextBlock Text="{Binding EndDate, StringFormat=yyyy. MM. dd.}" Foreground="White" FontSize="13"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding StatusIcon}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="14" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding StatusName}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="14"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:N2} €}" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <Button Content="⏳ Függőben" Foreground="White" Background="#4A90E2" BorderThickness="0" Width="95" FontSize="11" Padding="5,4" Margin="0,0,0,4" Click="BtnSetOrderPending_Click" Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button Content="🟢 Aktív" Foreground="White" Background="#4CAF50" BorderThickness="0" Width="95" FontSize="11" Padding="5,4" Margin="0,0,0,4" Click="BtnSetOrderActive_Click" Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button Content="✔️ Befejezve" Foreground="White" Background="#FF4B4B" BorderThickness="0" Width="95" FontSize="11" Padding="5,4" Click="BtnSetOrderCompleted_Click" Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>

                                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                    <Button Content="✏️ Szerkesztés" Style="{StaticResource CardButtonStyle}" FontSize="12" Padding="5,6" Margin="0,0,0,5" Click="BtnEditOrder_Click"/>
                                                    <Button Content="🗑️ Törlés" Style="{StaticResource CardButtonStyle}" Foreground="#FF6B6B" FontSize="12" Padding="5,6" Click="BtnDeleteOrder_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="pnlVehicles" Visibility="Hidden">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Autók listája" Foreground="{StaticResource TextWhite}" FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <Button Content="📄 Exportálás CSV-be" Style="{StaticResource GoldButtonStyle}" HorizontalAlignment="Right" Click="BtnExportVehicles_Click"/>
                </Grid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="Kategória:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cmbCategoryFilter" Width="90" FontSize="14" SelectionChanged="FilterVehicles_Changed" Padding="5" VerticalContentAlignment="Center" Margin="0,0,20,0">
                        <ComboBoxItem Content="Összes" IsSelected="True"/>
                        <ComboBoxItem Content="Sedan"/>
                        <ComboBoxItem Content="Coupe"/>
                        <ComboBoxItem Content="Hatchback"/>
                        <ComboBoxItem Content="SUV"/>
                        <ComboBoxItem Content="Wagon"/>
                        <ComboBoxItem Content="Minivan"/>
                        <ComboBoxItem Content="Luxury"/>
                    </ComboBox>
                    <TextBlock Text="Rendezés:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cmbSortVehicles" Width="135" FontSize="14" SelectionChanged="FilterVehicles_Changed" Padding="5" VerticalContentAlignment="Center" Margin="0,0,20,0">
                        <ComboBoxItem Content="Alapértelmezett" IsSelected="True"/>
                        <ComboBoxItem Content="Ár szerint (Növekvő)"/>
                        <ComboBoxItem Content="Ár szerint (Csökkenő)"/>
                    </ComboBox>
                    <TextBlock Text="Keresés:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="txtSearchVehicle" Width="120" Style="{StaticResource SearchTextBoxStyle}" TextChanged="FilterVehicles_Changed" Margin="0,0,20,0"/>
                    <TextBlock Text="Státusz:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <CheckBox x:Name="chkStatusAvailable" Content="Elérhető" IsChecked="True" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0" Checked="FilterVehicles_Changed" Unchecked="FilterVehicles_Changed"/>
                    <CheckBox x:Name="chkStatusRented" Content="Kiadva" IsChecked="True" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0" Checked="FilterVehicles_Changed" Unchecked="FilterVehicles_Changed"/>
                    <CheckBox x:Name="chkStatusMaintenance" Content="Szerviz" IsChecked="True" Foreground="White" VerticalAlignment="Center" Checked="FilterVehicles_Changed" Unchecked="FilterVehicles_Changed"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="+ Új autó" Style="{StaticResource GoldButtonStyle}" Click="BtnAddVehicle_Click"/>
                </StackPanel>
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="icVehicles">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A1A" CornerRadius="8" Margin="0,0,20,15" BorderBrush="#333" BorderThickness="1" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#CCCCCC" CornerRadius="8" Height="100" Width="160" Margin="0,0,20,0">
                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Clip>
                                                    <RectangleGeometry Rect="0,0,160,100" RadiusX="8" RadiusY="8"/>
                                                </Image.Clip>
                                            </Image>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentGold}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Brand}" Foreground="White" FontSize="22" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Model}" Foreground="#CCCCCC" FontSize="16"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <TextBlock Text="Státusz: " Foreground="Gray" FontSize="13"/>
                                                <TextBlock Text="{Binding StatusName}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="13" Margin="0,0,15,0"/>
                                                <TextBlock Text="Bérlések száma: " Foreground="Gray" FontSize="13"/>
                                                <TextBlock Text="{Binding TimesRented}" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Year}" Foreground="Gray" FontSize="14" Margin="0,0,0,5"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding PricePerDay}" Foreground="{StaticResource AccentGold}" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" € / nap" Foreground="{StaticResource AccentGold}" FontSize="16"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="✏️ Szerkesztés" Style="{StaticResource CardButtonStyle}" Click="BtnEdit_Click"/>
                                            <Button Content="🗑️ Törlés" Style="{StaticResource CardButtonStyle}" Foreground="#FF6B6B" Margin="10,0,0,0" Click="BtnDelete_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="pnlUsers" Visibility="Hidden">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Felhasználók listája" Foreground="White" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,20"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
                    <Button Content="+ Új felhasználó" Style="{StaticResource GoldButtonStyle}" Click="BtnAddUser_Click" Margin="0,0,20,0"/>
                    <TextBlock Text="Szűrés:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="cmbUserFilter" Width="100" FontSize="14" SelectionChanged="FilterUsers_Changed" Padding="5" VerticalContentAlignment="Center" Margin="0,0,25,0">
                        <ComboBoxItem Content="Összes" IsSelected="True"/>
                        <ComboBoxItem Content="Admin"/>
                        <ComboBoxItem Content="User"/>
                    </ComboBox>
                    <TextBlock Text="Állapot:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <CheckBox x:Name="chkVerified" Content="Hitelesített" IsChecked="True" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0" Checked="FilterUsers_Changed" Unchecked="FilterUsers_Changed"/>
                    <CheckBox x:Name="chkUnverified" Content="Nem hitelesített" IsChecked="True" Foreground="White" VerticalAlignment="Center" Margin="0,0,25,0" Checked="FilterUsers_Changed" Unchecked="FilterUsers_Changed"/>
                    <TextBlock Text="Keresés:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtSearchUser" Width="150" Style="{StaticResource SearchTextBoxStyle}" TextChanged="FilterUsers_Changed"/>
                </StackPanel>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icUsers">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A1A" CornerRadius="8" Margin="0,0,20,15" BorderBrush="#333" BorderThickness="1" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding RoleName}" Foreground="{StaticResource AccentGold}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Username}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding FullName}" Foreground="#CCC" FontSize="14"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Email}" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="{Binding PhoneNumber}" Foreground="Gray" FontSize="14"/>
                                            <TextBlock Text="{Binding VerifiedText}" Foreground="{Binding VerifiedColor}" FontSize="13" FontWeight="Bold" Margin="0,5,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="✏️ Szerkesztés" Style="{StaticResource CardButtonStyle}" Click="BtnEditUser_Click"/>
                                            <Button Content="🗑️ Törlés" Style="{StaticResource CardButtonStyle}" Foreground="#FF6B6B" Margin="10,0,0,0" Click="BtnDeleteUser_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="pnlDrivers" Visibility="Hidden">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,20">
                    <TextBlock Text="Sofőrök listája" Foreground="White" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="+ Új sofőr" Style="{StaticResource GoldButtonStyle}" Click="BtnAddDriver_Click" Margin="0,0,20,0"/>
                        <TextBlock Text="Keresés:" Foreground="{StaticResource TextWhite}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtSearchDriver" Width="200" Style="{StaticResource SearchTextBoxStyle}" TextChanged="FilterDrivers_Changed"/>
                    </StackPanel>
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icDrivers">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A1A" CornerRadius="8" Margin="0,0,20,15" BorderBrush="#333" BorderThickness="1" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding RoleName}" Foreground="{StaticResource AccentGold}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding FullName}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Username}" Foreground="#CCC" FontSize="14"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Email}" Foreground="White" FontSize="14"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Jogsi: " Foreground="Gray" FontSize="14"/>
                                                <TextBlock Text="{Binding LicenseNumber}" Foreground="{StaticResource AccentGold}" FontSize="14" FontWeight="Bold"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding VerifiedText}" Foreground="{Binding VerifiedColor}" FontSize="13" FontWeight="Bold" Margin="0,5,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="✏️ Szerkesztés" Style="{StaticResource CardButtonStyle}" Click="BtnEditUser_Click"/>
                                            <Button Content="🗑️ Törlés" Style="{StaticResource CardButtonStyle}" Foreground="#FF6B6B" Margin="10,0,0,0" Click="BtnDeleteUser_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

        </Grid>

        <Border x:Name="ToastNotification" Grid.ColumnSpan="2" Background="#2A2A2A" CornerRadius="5" Padding="20,10" 
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,30,30" Opacity="0" IsHitTestVisible="False"
                BorderBrush="{StaticResource AccentGold}" BorderThickness="1" Panel.ZIndex="100">
            <TextBlock x:Name="txtToastMessage" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
        </Border>

    </Grid>
</Window>