<Window x:Class="ExoticAdmin.VehicleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jármű Részletes Adatai" Height="750" Width="700"
        Background="{StaticResource PrimaryBlack}" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,10,0,2"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="JÁRMŰ KEZELÉSE" Foreground="{StaticResource AccentGold}" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
            <StackPanel>

                <TextBlock Text="Alapadatok &amp; Megjelenés" Foreground="{StaticResource AccentGold}" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,10"/>
                <WrapPanel>
                    <StackPanel Width="300" Margin="0,0,20,0">
                        <TextBlock Text="Márka"/>
                        <TextBox x:Name="txtBrand"/>
                        <TextBlock Text="Modell"/>
                        <TextBox x:Name="txtModel"/>
                        <TextBlock Text="Kategória (pl. Sedan, SUV)"/>
                        <TextBox x:Name="txtCategory"/>
                        <TextBlock Text="Évjárat"/>
                        <TextBox x:Name="txtYear"/>
                        <TextBlock Text="Napi ár (€)"/>
                        <TextBox x:Name="txtPrice"/>
                    </StackPanel>
                    <StackPanel Width="300">
                        <TextBlock Text="Külső szín"/>
                        <TextBox x:Name="txtColor"/>
                        <TextBlock Text="Belső tér (Interior)"/>
                        <TextBox x:Name="txtInterior"/>
                        <TextBlock Text="Ajtók száma"/>
                        <TextBox x:Name="txtDoors"/>
                        <TextBlock Text="Súly (kg)"/>
                        <TextBox x:Name="txtWeight"/>
                        <TextBlock Text="Felni stílus"/>
                        <TextBox x:Name="txtWheel"/>
                    </StackPanel>
                </WrapPanel>

                <TextBlock Text="Elsődleges kép URL (URL link)"/>
                <TextBox x:Name="txtImageUrl" Margin="0,0,0,20"/>

                <TextBlock Text="Teljesítmény &amp; Hajtáslánc" Foreground="{StaticResource AccentGold}" FontSize="18" FontWeight="SemiBold" Margin="0,30,0,10"/>
                <WrapPanel>
                    <StackPanel Width="300" Margin="0,0,20,0">
                        <TextBlock Text="Motor / Powertrain"/>
                        <TextBox x:Name="txtPowertrain"/>
                        <TextBlock Text="Váltó"/>
                        <TextBox x:Name="txtTransmission"/>
                        <TextBlock Text="Meghajtás (Drive)"/>
                        <TextBox x:Name="txtDrive"/>
                    </StackPanel>
                    <StackPanel Width="300">
                        <TextBlock Text="Lóerő (HP)"/>
                        <TextBox x:Name="txtHp"/>
                        <TextBlock Text="Nyomaték (Nm)"/>
                        <TextBox x:Name="txtTorque"/>
                        <TextBlock Text="Gyorsulás 0-100 (pl. 3.5s)"/>
                        <TextBox x:Name="txtAcceleration"/>
                        <TextBlock Text="Végsebesség (km/h)"/>
                        <TextBox x:Name="txtTopSpeed"/>
                    </StackPanel>
                </WrapPanel>

                <TextBlock Text="Leírás &amp; Extrák" Foreground="{StaticResource AccentGold}" FontSize="18" FontWeight="SemiBold" Margin="0,30,0,10"/>

                <TextBlock Text="🔧 Szerviz &amp; Karbantartás" Foreground="{StaticResource AccentGold}" FontSize="18" FontWeight="SemiBold" Margin="0,30,0,10"/>
                <WrapPanel>
                    <StackPanel Width="300" Margin="0,0,20,0">
                        <TextBlock Text="Jelenlegi kilométeróra állás"/>
                        <TextBox x:Name="txtMileage"/>
                    </StackPanel>
                    <StackPanel Width="300">
                        <TextBlock Text="Műszaki vizsga lejárata (ÉÉÉÉ-HH-NN)"/>
                        <TextBox x:Name="txtMotExpiry"/>
                    </StackPanel>
                </WrapPanel>
                <TextBlock Text="Karbantartási napló (Olajcsere, javítások stb.)"/>
                <TextBox x:Name="txtMaintenance" TextWrapping="Wrap" Height="80" AcceptsReturn="True" Margin="0,0,0,20"/>

                <StackPanel>
                    <TextBlock Text="Státusz (1=Elérhető, 2=Kiadva, 3=Szerviz)"/>
                    <TextBox x:Name="txtStatus"/>

                    <TextBlock Text="Extrák (vesszővel elválasztva)"/>
                    <TextBox x:Name="txtExtras" TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                    <TextBlock Text="Részletes leírás"/>
                    <TextBox x:Name="txtDescription" TextWrapping="Wrap" Height="100" AcceptsReturn="True"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Mégse" Style="{StaticResource FlatButtonStyle}" Width="100" Padding="12" Background="#444" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="BtnCancel_Click" Cursor="Hand"/>
            <Button Content="Mentés" Style="{StaticResource FlatButtonStyle}" Width="150" Padding="12" Background="{StaticResource AccentGold}" Foreground="Black" FontWeight="Bold" BorderThickness="0" Click="BtnSave_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>